# Copy this file to .env (or .env.local for secrets) and fill in the values.

# ── Contributors ───────────────────────────────────────────────────────
# The landing page always shows the UNION of:
#   1. GitHub contributors from every repo listed in GITHUB_REPOS below
#      (resolved via the dev `/api/contributors` middleware, or direct
#      browser calls in prod), and
#   2. The backend's `GET /contributors` collection (Mongo-backed; the
#      backend re-validates each stored username against GitHub on every
#      request and drops anyone whose account 404s).
# Deduplicated by username.

# Comma-separated GitHub repos (owner/name) whose contributors get unioned.
# Falls back to legacy GITHUB_REPO if unset.
GITHUB_REPOS=MicrosoftStudentChapter/mlsc-timetable,MicrosoftStudentChapter/mlsc-timetable-backend

# Legacy single-repo var, kept for back-compat. Prefer GITHUB_REPOS above.
GITHUB_REPO=MicrosoftStudentChapter/mlsc-timetable

# Optional: personal access token to avoid the 60 req/hr unauthenticated
# rate limit on the dev middleware. Use a fine-grained token with read-only
# "public repo" access. Keep in .env.local; never commit.
# GITHUB_TOKEN=your_token_here

# ── Backend ────────────────────────────────────────────────────────────
# Base URL of the timetable backend (FastAPI). The frontend hits:
#   ${VITE_BACKEND_URL}/batch        (batch directory)
#   ${VITE_BACKEND_URL}/current      (current semester label)
#   ${VITE_BACKEND_URL}/contributors (db / union modes only)
# If unset or unreachable, the frontend falls back to src/data/batches.json.
# Must use the VITE_ prefix so it is exposed to the browser.
VITE_BACKEND_URL=http://localhost:8000

# ── Auth (Clerk) ───────────────────────────────────────────────────────
# Publishable key from the Clerk dashboard (Settings → API Keys).
# Enable only "Email" and "Google" in Clerk dashboard → User & Auth → SSO
# Connections / Auth Strategies. App throws at startup if this is missing.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
